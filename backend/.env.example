# ---------------------------------------------------------------------------
# Modèle d'environnement backend Onskoné.
# Sur le VPS : copier en `backend/.env` et remplir. NE JAMAIS committer le .env
# (il est déjà gitignoré). Chargé automatiquement par `dotenv/config`.
# ---------------------------------------------------------------------------

NODE_ENV=production
PORT=8080

# Origin(s) public(s) autorisé(s) pour CORS, séparés par des virgules.
# ⚠️ Si vide en production, le backend REFUSE toutes les requêtes navigateur.
# (ajoute https://www.onskone.fr si tu sers aussi le www)
ALLOWED_ORIGINS=https://onskone.fr

# Mot de passe du panneau /admin (à définir, fort et unique).
ADMIN_PASSWORD=

# Secret de signature des tokens admin (HMAC). Génère-le avec :
#   openssl rand -hex 32
ADMIN_TOKEN_SECRET=

# Niveau de log : error | warn | info | debug
LOG_LEVEL=info

# --- Optionnels (les valeurs par défaut conviennent si le repo est cloné tel quel) ---
# Chemin absolu du frontend buildé (défaut: ../frontend/build relatif au backend)
# FRONTEND_DIST=/home/onskone/Onskone/frontend/build
# Chemin de la base SQLite des tickets (défaut: backend/data/onskone.db)
# DB_PATH=/home/onskone/Onskone/backend/data/onskone.db
